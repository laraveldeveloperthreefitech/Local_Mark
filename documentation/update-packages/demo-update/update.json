{
    "version": "1.1.1",
    "min_app_version": "1.1.0",
    "run_migrations": true,
    "notes": "Version 1.1.1 introduces advanced notifications, smart product filtering, OTP login, purchase validation, map-based store browsing, delivery zone display, and major feature enhancements across Admin, Seller, Rider, Customer App, and Web platforms.",
    "run_seeders": false,
    "vendor_update": false,
    "actions": [
        {
            "type": "add",
            "source": "app",
            "target": "app"
        },
        {
            "type": "add",
            "source": "config",
            "target": "config"
        },
        {
            "type": "add",
            "source": "bootstrap/app.php",
            "target": "bootstrap/app.php"
        },
        {
            "type": "add",
            "source": "database",
            "target": "database"
        },
        {
            "type": "add",
            "source": "packages",
            "target": "packages"
        },
        {
            "type": "add",
            "source": "resources",
            "target": "resources"
        },
        {
            "type": "add",
            "source": "routes",
            "target": "routes"
        },
        {
            "type": "add",
            "source": "public/assets/admin",
            "target": "public/assets/admin"
        },
        {
            "type": "add",
            "source": "public/assets/css",
            "target": "public/assets/css"
        },
        {
            "type": "add",
            "source": "public/assets/js",
            "target": "public/assets/js"
        },
        {
            "type": "add",
            "source": "public/assets/seller",
            "target": "public/assets/seller"
        }
    ],
    "commands": [
        "config:clear",
        "config:cache",
        "route:clear",
        "view:clear",
        "view:cache"
    ]
}
